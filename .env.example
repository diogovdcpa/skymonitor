# SkyMonitor API configuration
# Para o script PowerShell de exportacao, SKY_EMAIL e SKY_PASSWORD sao o minimo necessario.
# Defina SKY_BASE_URL tambem se quiser fixar o host do tenant.
# You can set one preferred host...
SKY_BASE_URL=https://www.myshn.net
# ...or a comma-separated candidate list for auto-detection.
# SKY_BASE_URLS=https://www.myshn.net,https://www.myshn.eu,https://www.myshn.ca,https://www.govshn.net
SKY_EMAIL=seu-email@empresa.com
SKY_PASSWORD=sua-senha-aqui

# Auth mode: auto | skyhigh | legacy | basic-only | iam-tenant
# Se omitido, o CLI assume basic-only.
SKY_AUTH_MODE=basic-only
SKY_TENANT_ID=

# Optional paths (defaults already set no pacote skymonitor)
SKY_AUTH_PATH=/auth/login
SKY_INCIDENTS_PATH=/shnapi/rest/external/api/v1/queryIncidents

# queryIncidents request options
SKY_START_TIME=2020-04-12T09:30:00.000Z
# Example:
# SKY_INCIDENT_CRITERIA_JSON={"categories":[{"incidentType":"Alert.Policy.Epo"}]}
SKY_INCIDENT_CRITERIA_JSON=

# Optional pagination tuning
SKY_PAGE_SIZE=200
SKY_MAX_PAGES=1000
